rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helpers (lisibilité + validation) =====
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }
    // Un tableau ne peut que basculer l'uid de l'appelant (follow, likedBy, viewedBy…)
    function togglesSelfOnly(field) {
      return
        ( request.resource.data[field].hasAny([request.auth.uid]) &&
          ( !(field in resource.data) || !resource.data[field].hasAny([request.auth.uid]) ) )
        ||
        ( (field in resource.data) &&
          resource.data[field].hasAny([request.auth.uid]) &&
          !request.resource.data[field].hasAny([request.auth.uid]) );
    }

    match /users/{userId} {
      // ⚠️ read public conservé pour u/[pseudo] + deep links.
      // NE STOCKE JAMAIS email/tel/données privées dans ce doc.
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isSignedIn() && (
        request.auth.uid == userId ||
        (changedKeys().hasOnly(['followers','followerCount']) && togglesSelfOnly('followers')) ||
        (changedKeys().hasOnly(['followers','followerCount']) &&
         'followers' in resource.data &&
         resource.data.followers.hasAny([request.auth.uid]) &&
         !request.resource.data.followers.hasAny([request.auth.uid])) ||
        (changedKeys().hasOnly(['pendingFollowers']) && togglesSelfOnly('pendingFollowers')) ||
        (changedKeys().hasOnly(['pendingFollowers']) &&
         'pendingFollowers' in resource.data &&
         resource.data.pendingFollowers.hasAny([request.auth.uid]) &&
         !request.resource.data.pendingFollowers.hasAny([request.auth.uid])) ||
        (changedKeys().hasOnly(['pendingFollowings']) &&
         'pendingFollowings' in resource.data &&
         resource.data.pendingFollowings.hasAny([request.auth.uid]) &&
         !request.resource.data.pendingFollowings.hasAny([request.auth.uid])) ||
        (changedKeys().hasOnly(['following','followingCount','pendingFollowings']) &&
         request.resource.data.following.hasAny([request.auth.uid]) &&
         (!('following' in resource.data) || !resource.data.following.hasAny([request.auth.uid])) &&
         'pendingFollowings' in resource.data &&
         resource.data.pendingFollowings.hasAny([request.auth.uid]) &&
         !request.resource.data.pendingFollowings.hasAny([request.auth.uid])) ||
        // blocage : seul l'appelant peut (se) toggler dans blockedBy
        (changedKeys().hasOnly(['blockedBy','followers','following']) && togglesSelfOnly('blockedBy'))
      );
      allow delete: if isOwner(userId);
    }

    // Le mapping username appartient à l'appelant (uid)
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /videos/{videoId} {
      allow read: if isSignedIn();
      // l'auteur déclaré = l'appelant ; moderationStatus/hiddenAt/hiddenReason SERVER-ONLY
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && !('moderationStatus' in request.resource.data)
        && !('hiddenAt' in request.resource.data)
        && !('hiddenReason' in request.resource.data);
      // ✅ VERROU : compteurs & tableaux (likes/likedBy/saves/savedBy/reposts/
      // repostedBy/latestRepostedBy/comments/previewComments/shares/views) sont
      // possédés par les Cloud Functions (Admin SDK). Le client ne touche le doc
      // vidéo que s'il en est l'auteur, et jamais les champs de modération.
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.userId
        && !changedKeys().hasAny(['moderationStatus','hiddenAt','hiddenReason']);
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;

      // vue par user (onViewCreate côté serveur)
      match /views/{userId} {
        allow read: if isSignedIn();
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      match /likes/{userId} {
        allow read: if isSignedIn();
        allow create, delete: if isOwner(userId);
      }
      match /saves/{userId} {
        allow read: if isSignedIn();
        allow create, delete: if isOwner(userId);
      }
      match /comments/{commentId} {
        allow read: if isSignedIn();
        // auteur = appelant, texte borné
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;
        allow update: if isSignedIn() && (
          request.auth.uid == resource.data.userId ||
          ( changedKeys().hasOnly(['likes','likedBy','dislikes','dislikedBy','replyCount'])
            && ( !changedKeys().hasAny(['likedBy'])    || togglesSelfOnly('likedBy') )
            && ( !changedKeys().hasAny(['dislikedBy']) || togglesSelfOnly('dislikedBy') )
          )
        );
        allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;

        match /replies/{replyId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn()
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 2000;
          allow update: if isSignedIn() && (
            request.auth.uid == resource.data.userId ||
            ( changedKeys().hasOnly(['likes','likedBy','dislikes','dislikedBy'])
              && ( !changedKeys().hasAny(['likedBy'])    || togglesSelfOnly('likedBy') )
              && ( !changedKeys().hasAny(['dislikedBy']) || togglesSelfOnly('dislikedBy') )
            )
          );
          allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
        }
      }
    }

    match /messages/{messageId} {
      allow read: if isSignedIn()
        && resource.data.participants != null
        && resource.data.participants.hasAny([request.auth.uid]);
      // expéditeur = appelant ET participant
      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.participants.hasAny([request.auth.uid]);
      allow delete: if isSignedIn() && request.auth.uid == resource.data.senderId;
    }

    match /conversations/{conversationId} {
      allow read: if isSignedIn()
        && (resource == null || resource.data.participants.hasAny([request.auth.uid]));
      allow create: if isSignedIn()
        && request.resource.data.participants.hasAny([request.auth.uid]);
      allow update: if isSignedIn()
        && resource.data.participants.hasAny([request.auth.uid]);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants.hasAny([request.auth.uid]);
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
        allow update: if false;
        allow delete: if isSignedIn() && request.auth.uid == resource.data.senderId;
      }
    }

    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        ( changedKeys().hasOnly(['views','viewedBy']) && togglesSelfOnly('viewedBy') )
      );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /reposts/{repostId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /highlights/{highlightId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /shares/{shareId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      allow update: if false;
    }

    match /reports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.reportedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.reason is string
        && request.resource.data.targetId is string;
      allow read: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
