{
  "name": "mbolo",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild --clean",
    "build:android": "eas build --profile development --platform android",
    "build:ios": "eas build --profile development --platform ios",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:production": "eas build --profile production --platform all",
    "graphify:roles": "node scripts/enrich-graphify-roles.js",
    "graphify:refresh": "graphify update . && node scripts/enrich-graphify-roles.js",
    "arch:check": "bash scripts/arch-check.sh",
    "firebase:analyze": "node scripts/analyze-firebase.mjs",
    "firebase:login": "npx firebase-tools login",
    "firebase:deploy:rules": "npx firebase-tools deploy --only firestore:rules",
    "firebase:deploy:indexes": "npx firebase-tools deploy --only firestore:indexes",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:screenshots": "playwright test e2e/screenshots.spec.ts",
    "test:e2e:headed": "playwright test --headed",
    "mcp:playwright": "npx @playwright/mcp",
    "postinstall": "node scripts/patch-ffmpeg-podspec.js && node scripts/patch-expo-image-contentposition.js"
  },
  "dependencies": {
    "@babel/traverse": "^7.29.0",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@sentry/react-native": "~6.5.0",
    "expo": "~54.0.33",
    "expo-av": "^16.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.22",
    "expo-gl": "~16.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.16",
    "expo-video-thumbnails": "~10.0.8",
    "ffmpeg-kit-react-native": "^6.0.2",
    "firebase": "^12.13.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-image-filter-kit": "^0.8.0",
    "react-native-nitro-modules": "^0.35.7",
    "react-native-pager-view": "6.9.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-vision-camera": "^5.0.9",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.75",
    "@playwright/test": "^1.60.0",
    "@types/react": "~19.1.0",
    "eas-cli": "^18.13.1",
    "firebase-admin": "^13.10.0",
    "firebase-tools": "^15.18.0",
    "playwright": "^1.60.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
